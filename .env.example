# Copy to .env and fill in. Backend reads these at startup.

# Gemini API key — required for VOICE. Without it the server still runs and the
# direct-command path (buttons) works; only audio parsing is disabled.
GEMINI_API_KEY=

# Model for STT + intent function-calling. Flash-Lite (Gemini 3.1) has more
# free-tier headroom than the flagship Flash, which often returns 503 "high
# demand" on free tier. Override if you have paid-tier access to a bigger model.
GEMINI_MODEL=gemini-flash-lite-latest

# Shared secret the ESP32 presents in its hello frame (must match firmware DEVICE_TOKEN).
DEVICE_TOKEN=change-me-device

# Bearer token the browser must pass as ?token= to open the web socket.
BROWSER_TOKEN=change-me-browser

# HTTP/WS port.
PORT=8080

# How long (ms) to wait for a Tello reply relayed via the ESP32 before reporting timeout.
COMMAND_TIMEOUT_MS=8000

# ---- ArUco marker-follow (see README.md's "ArUco marker-follow" section) ----

# UDP port the backend listens on for the ESP32's raw Tello-video relay. Must
# match VIDEO_PORT in firmware/src/config.h.
VIDEO_PORT=8890

# Tello's `streamon` resolution (SDK default). Must match on both ends -- no
# negotiation, a mismatch just decodes garbage.
VIDEO_WIDTH=960
VIDEO_HEIGHT=720

# js-aruco2 dictionary. "ARUCO_MIP_36h12" (default) is the modern dictionary;
# use "ARUCO" for the classic OpenCV 5x5 original dictionary.
ARUCO_DICTIONARY=ARUCO_MIP_36h12

# Track only this marker id; leave unset to follow whichever marker is seen.
# ARUCO_TARGET_ID=0

# Max Hamming distance (out of 16 bits) still counted as a match for a
# web-drawn custom 4x4 marker (see the marker-designer UI). Higher = more
# tolerant of camera noise but more false-positive-prone -- kept strict by
# default since a physical drone steering off a false positive is worse
# than occasionally missing its own marker in poor lighting. 0 does NOT
# mean "exact match only" (see registerCustomMarker in src/tracking.ts).
ARUCO_CUSTOM_TAU=2

# Apparent marker size (px, avg side length) that means "at the right
# distance" -- bigger observed size => drone thinks it's too close and backs
# off. Tune empirically for your printed marker size + desired follow distance.
ARUCO_TARGET_SIZE_PX=160

# Safety clamp on every rc channel (-max..max, of a possible -100..100). Keep
# low until the loop's behavior is confirmed sane on a real flight.
TRACK_MAX_RC=35

# Proportional gains (yaw from horizontal offset, throttle from vertical
# offset, pitch from distance/size error). Plain multipliers -- if the drone
# turns/climbs/moves the wrong way on first test, flip the sign, no redeploy
# needed for anything else.
TRACK_YAW_GAIN=60
TRACK_ALT_GAIN=60
TRACK_DIST_GAIN=80

# ---- Live camera preview (browser UI -- separate JPEG stream, independent
# of the ArUco math above) ----

# Preview width in px; height auto-scales to preserve aspect ratio. Smaller
# = less bandwidth to the browser and less ffmpeg CPU.
VIDEO_PREVIEW_WIDTH=480

# ffmpeg -q:v for the preview MJPEG stream: 2 (best) .. 31 (worst).
VIDEO_PREVIEW_QUALITY=6

# Upper bound on preview frames forwarded to browsers per second,
# independent of ffmpeg's actual decode rate.
VIDEO_PREVIEW_MAX_FPS=12

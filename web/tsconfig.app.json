{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path alias (shadcn/ui convention). No baseUrl -- deprecated in TS 6,
     * paths resolve relative to this tsconfig file without it. */
    "paths": { "@/*": ["./src/*"] },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  /* ../src/protocol.ts: the Bun backend's wire-contract types, imported
   * directly (see src/lib/ws-protocol.ts) so the frontend can never drift
   * from the backend's message shapes without a compile error. */
  "include": ["src", "../src/protocol.ts"],
  /* *.test.ts files are checked separately by tsconfig.test.json, which
   * needs bun-types (for `bun:test` + the `Bun` global that
   * ../src/tracking.ts uses) -- globals the app build must NOT see. */
  "exclude": ["src/**/*.test.ts"]
}
